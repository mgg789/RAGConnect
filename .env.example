# Copy this file to .env and fill in your values.
# docker compose will pick it up automatically.

OPENAI_API_KEY=sk-replace-me
# OPENAI_API_BASE=https://api.openai.com/v1 # This is URL to your AI API (via openaai SDK) (openai default)
RAGCONNECT_HTTP_TIMEOUT_SECONDS=600

# Optional LLM override.
LLM_MODEL=gpt-5.4-mini

# By default RAGConnect uses a local embedding model behind a lightweight proxy.
LOCAL_EMBEDDING_MODE=true
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
LOCAL_EMBEDDING_DIM=384
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384
PROXY_PORT=9622

# Optional: use a dedicated embedding API instead of the local model.
# EMBEDDING_API_BASE=https://your-compatible-embedding-endpoint/v1
# EMBEDDING_API_KEY=replace_me

RAGCONNECT_ADMIN_USERNAME=admin
RAGCONNECT_ADMIN_PASSWORD=replace_me

# Optional production graph backend.
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=replace_me
# NEO4J_DATABASE=neo4j

# Optional hardening knobs.
# RAGCONNECT_RATE_LIMIT_REQUESTS=120
# RAGCONNECT_RATE_LIMIT_WINDOW_SECONDS=60
# RAGCONNECT_ADMIN_MAX_ATTEMPTS=5
# RAGCONNECT_ADMIN_WINDOW_SECONDS=300
# RAGCONNECT_ADMIN_BLOCK_SECONDS=900

# Host helper / backups.
# Start the host helper on the machine that runs docker:
#   ragconnect-host-helper daemon --repo-root /path/to/RAGConnect
# Backup schedule and retention are stored in control/state/helper_config.json.
