# Copy this file to .env and fill in your values.
# docker compose will pick it up automatically.

# ---- LightRAG LLM backend ----
OPENAI_API_KEY=sk-replace-me

# Optional: use a different OpenAI-compatible endpoint (e.g. Azure, local Ollama proxy)
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional: override default models
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# Optional: OpenAI-compatible endpoint URL
# OPENAI_API_BASE=https://api.openai.com/v1

# Server Gateway admin credentials (required for /admin/* endpoints)
RAGCONNECT_ADMIN_USERNAME=admin
RAGCONNECT_ADMIN_PASSWORD=replace_me

# Recommended production graph backend (Neo4j)
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=replace_me
# NEO4J_DATABASE=neo4j
