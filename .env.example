# Copy this file to .env and fill in your values.
# docker compose will pick it up automatically.

# ---- LightRAG LLM backend ----
OPENAI_API_KEY=sk-replace-me

# Optional: override the OpenAI-compatible endpoint for the LLM
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional: override default models
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# ---- Separate embedding API (optional) --------------------------------
# By default, embeddings use the same key/endpoint as the LLM.
# Set these to route embeddings to a different provider (e.g. Jina Cloud, Cohere, local).
# EMBEDDING_API_KEY=sk-replace-me
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_DIM=1536

# ---- Local embedding mode (Jina from HuggingFace, no API key needed) --
# When enabled, a lightweight Jina model is loaded locally for embeddings.
# Requires sentence-transformers; the model is downloaded on first start.
# LOCAL_EMBEDDING_MODE=false
# LOCAL_EMBEDDING_MODEL=jinaai/jina-embeddings-v2-small-en
# LOCAL_EMBEDDING_DIM=512

# Server Gateway admin credentials (required for /admin/* endpoints)
RAGCONNECT_ADMIN_USERNAME=admin
RAGCONNECT_ADMIN_PASSWORD=replace_me

# API rate limiting and admin brute-force protection
# RAGCONNECT_RATE_LIMIT_REQUESTS=120
# RAGCONNECT_RATE_LIMIT_WINDOW_SECONDS=60
# RAGCONNECT_ADMIN_MAX_ATTEMPTS=5
# RAGCONNECT_ADMIN_WINDOW_SECONDS=300
# RAGCONNECT_ADMIN_BLOCK_SECONDS=900

# Recommended production graph backend (Neo4j)
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=replace_me
# NEO4J_DATABASE=neo4j
